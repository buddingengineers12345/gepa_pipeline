{
  "mcpServers": {
    "agentmemory": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@agentmemory/mcp"],
      "tools": ["*"],
      "env": {
        "AGENTMEMORY_TEAM_ID": "gepa_pipeline",
        "AGENTMEMORY_URL": "http://localhost:3111",
        "AGENTMEMORY_TOOLS": "all"
      }
    }
  }
}
